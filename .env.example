# OAIWeb Digital — environment variables
# Copy this file to .env.local (Vercel: Project Settings → Environment Variables)

# Telegram bot that receives lead-form submissions from /api/submit
# 1. Open @BotFather in Telegram → /newbot → follow prompts → copy HTTP API token
TELEGRAM_BOT_TOKEN=

# Chat / channel / supergroup ID where leads are delivered
# - For a private chat: send any message to the bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
# - For a supergroup/channel: add the bot as admin, then read chat.id from getUpdates (negative number, e.g. -1001234567890)
TELEGRAM_CHAT_ID=
