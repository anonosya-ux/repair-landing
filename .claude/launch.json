{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vercel-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "vercel", "dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "static-python",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "static-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "-l", "5173", "."],
      "port": 5173
    }
  ]
}
